import cv2
from ultralytics import YOLO

# model yükleme
model = YOLO("yolov8n.pt")

# kamera açma
cap = cv2.VideoCapture(0)

while True:
    ret, frame = cap.read()

    if ret == False:
        break

    # frame'i modele ver
    results = model(frame)

    # tespit edilen nesneleri kutu olarak çiz
    annotated_frame = results[0].plot()

    cv2.imshow("frame", annotated_frame)

    key = cv2.waitKey(1)

    # q ile çık
    if key == ord("q"):
        break

cap.release()
cv2.destroyAllWindows()